# ─── Base de datos (Postgres) ───────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ─── NextAuth ───────────────────────────────────────────────
AUTH_SECRET="genera-uno-con: openssl rand -base64 32"

# URL pública de la app (sin barra final). Usada para enlaces de
# booking/dashboard y como base del redirect URI de OAuth.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Dominio raíz para resolver tenants por subdominio (opcional)
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"

# ─── Google Calendar (integración por tenant) ───────────────
# Una sola app OAuth para toda la plataforma. Créala en
# https://console.cloud.google.com → habilita "Google Calendar API"
# → Credenciales → OAuth 2.0 Client ID (tipo "Web application").
#
# Redirect URI autorizado (debe coincidir EXACTO):
#   {NEXT_PUBLIC_APP_URL}/api/integrations/google/callback
#   ej: https://tu-app.vercel.app/api/integrations/google/callback
#
# Scopes que la app solicita: calendar.events, calendar.readonly, userinfo.email
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Resend (emails transaccionales) ───────────────────────
# Obtén tu API key en https://resend.com → Settings → API Keys
# Luego verifica tu dominio en Resend → Domains para enviar
# desde tu propio dominio en lugar de onboarding@resend.dev
RESEND_API_KEY=""
